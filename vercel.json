{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "env": [
    {
      "key": "NEXT_PUBLIC_SANITY_PROJECT_ID",
      "description": "Your Sanity project ID (get from sanity.io/manage)",
      "value": ""
    },
    {
      "key": "NEXT_PUBLIC_SANITY_DATASET",
      "description": "Sanity dataset name (usually 'production')",
      "value": "production"
    },
    {
      "key": "NEXT_PUBLIC_SANITY_API_VERSION",
      "description": "Sanity API version",
      "value": "2024-01-01"
    },
    {
      "key": "NEXT_PUBLIC_SITE_URL",
      "description": "Your production site URL",
      "value": ""
    },
    {
      "key": "SANITY_API_TOKEN",
      "description": "Sanity API token for preview mode (optional)",
      "value": ""
    }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/.*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/revalidate",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
