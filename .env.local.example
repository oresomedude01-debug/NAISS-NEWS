# NAISS News Platform - Environment Variables

# Sanity CMS Configuration
# Get these from your Sanity project settings: https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (for previews - optional)
# Only needed if you want to enable live preview mode
SANITY_API_TOKEN=YOUR_TOKEN_HERE

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (Optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G_XXXXXXXXXXXXX
